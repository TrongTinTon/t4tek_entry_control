<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_entry_control_token_wizard_form" model="ir.ui.view">
        <field name="name">entry.control.token.wizard.form</field>
        <field name="model">entry.control.token.wizard</field>
        <field name="arch" type="xml">
            <form string="Controller Token">
                <sheet>
                    <group>
                        <field name="controller_id"/>
                        <field name="note" nolabel="1"/>
                        <field name="token" nolabel="1"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Close" class="btn-primary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
