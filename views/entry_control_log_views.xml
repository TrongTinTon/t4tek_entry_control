<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_entry_control_log_search" model="ir.ui.view">
        <field name="name">entry.control.log.search</field>
        <field name="model">entry.control.log</field>
        <field name="arch" type="xml">
            <search string="Tìm kiếm Logs">
                <field name="device_user_id"/>
                <field name="employee_id"/>
                <field name="entry_user_id"/>
                <filter string="Truy cập không hợp lệ" name="invalid_access" domain="[('action','=','invalid_access')]"/>
                <filter string="Theo Nhân viên" name="group_by_employee" context="{'group_by':'employee_id'}"/>
            </search>
        </field>
    </record>

    <record id="view_entry_control_log_list" model="ir.ui.view">
        <field name="name">entry.control.log.list</field>
        <field name="model">entry.control.log</field>
        <field name="arch" type="xml">
            <list string="Entry Control Logs" decoration-danger="status == 'error'" decoration-success="status == 'success'">
                <field name="event_time" string="Thời gian"/>
                <field name="controller_ref_id" string="Controller"/>
                <field name="device_user_id" string="User ID"/>
                <field name="entry_user_id" string="Device User" optional="show"/>
                <field name="employee_id" string="Nhân viên" widget="many2one_avatar_employee"/>
                <field name="controller_id" string="Controller ID" optional="hide"/>
                <field name="device_ip" string="Device IP" optional="hide"/>
                <field name="action" widget="badge" 
                       decoration-info="action == 'check_in'" 
                       decoration-warning="action == 'check_out'"
                       decoration-danger="action == 'invalid_access'"/>
                <field name="status" widget="badge" 
                       decoration-success="status == 'success'" 
                       decoration-danger="status == 'error'"/>
            </list>
        </field>
    </record>

    <record id="view_entry_control_log_form" model="ir.ui.view">
        <field name="name">entry.control.log.form</field>
        <field name="model">entry.control.log</field>
        <field name="arch" type="xml">
            <form string="Chi tiết Nhật ký">
                <sheet>
                    <group>
                        <group string="Thông tin Người dùng">
                            <field name="employee_id" widget="many2one_avatar_employee"/>
                            <field name="entry_user_id"/>
                            <field name="device_user_id"/>
                        </group>
                        <group string="Thông tin Sự kiện">
                            <field name="event_time"/>
                            <field name="action"/>
                            <field name="status"/>
                            <field name="error_message" invisible="status == 'success'"/>
                            
                            <field name="raw_payload" invisible="True"/> 
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_entry_control_log" model="ir.actions.act_window">
        <field name="name">Nhật ký Vào/Ra Real-time</field>
        <field name="res_model">entry.control.log</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_entry_control_employee_list" model="ir.ui.view">
        <field name="name">entry.control.employee.list</field>
        <field name="model">hr.employee</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <list string="Danh sách Nhân sự Vào/Ra">
                <field name="name"/>
                <field name="department_id"/>
                <field name="job_title"/>
            </list>
        </field>
    </record>

    <record id="view_entry_control_employee_form" model="ir.ui.view">
            <field name="name">entry.control.employee.form</field>
            <field name="model">hr.employee</field>
            <field name="priority">99</field>
            <field name="arch" type="xml">
                <form string="Chi tiết Vào/Ra" create="false" edit="false"> 
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                        </div>
                        <notebook>
                            <page string="Bảng Lịch sử Vào/Ra">
                                <field name="entry_control_log_ids" readonly="1">
                                    <list decoration-danger="status == 'error'" decoration-success="status == 'success'">
                                        <field name="event_time" string="Thời gian"/>
                                        
                                        <field name="controller_id" string="Controller ID" optional="hide"/>
                                        <field name="controller_ref_id" string="Controller" optional="show"/>
                                        <field name="device_ip" string="IP Thiết bị" optional="hide"/>
                                        
                                        <field name="device_user_id" string="User ID (Thiết bị)"/>
                                        <field name="entry_user_id" string="Device User" optional="hide"/>
                                        <field name="controller_id" string="Controller ID" optional="hide"/>
                <field name="device_ip" string="Device IP" optional="hide"/>
                <field name="action" widget="badge" decoration-info="action == 'check_in'" decoration-warning="action == 'check_out'"
                       decoration-danger="action == 'invalid_access'"/>
                                        <field name="status" widget="badge" decoration-success="status == 'success'" decoration-danger="status == 'error'"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

    <record id="action_entry_control_employee_logs" model="ir.actions.act_window">
        <field name="name">Nhật ký theo Nhân viên</field>
        <field name="res_model">hr.employee</field> <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_entry_control_employee_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_entry_control_employee_form')})]"/>
    </record>
</odoo>