<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_entry_control_user_list" model="ir.ui.view">
        <field name="name">entry.control.user.list</field>
        <field name="model">entry.control.user</field>
        <field name="arch" type="xml">
            <list string="Device Users" create="1" edit="1">
                <header>
                    <button name="%(action_entry_control_generate_users_wizard)d" type="action" string="Generate from Employees" class="btn-primary" display="always"/>
                </header>
                <field name="employee_id"/>
                <field name="pin"/>
                <field name="name"/>
                <field name="card_no"/>
                <field name="privilege"/>
                <field name="group_no"/>
                <field name="timezone_no"/>
                <field name="is_active"/>
                <field name="is_deleted"/>
                <field name="fingerprint_count"/>
            </list>
        </field>
    </record>
    <record id="view_entry_control_user_form" model="ir.ui.view">
        <field name="name">entry.control.user.form</field>
        <field name="model">entry.control.user</field>
        <field name="arch" type="xml">
            <form string="Device User">
                <header>
                    <button name="%(action_entry_control_generate_users_wizard)d" type="action" string="Generate from Employees" class="btn-primary" display="always"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="pin" readonly="employee_id"/>
                            <field name="name"/>
                            <field name="password" password="True"/>
                            <field name="card_no"/>
                        </group>
                        <group>
                            <field name="privilege"/>
                            <field name="group_no"/>
                            <field name="timezone_no"/>
                            <field name="is_active"/>
                            <field name="is_deleted"/>
                            <field name="fingerprint_count" readonly="1"/>
                        </group>
                    </group>
                    <group string="Sync rule">
                        <div class="text-muted" colspan="2">
                            Device Users are the desired-state master data. Controllers pull /api/entry_control/v1/sync/manifest by last_sync_version, compare local/device state, then execute only the required delta jobs. PIN is referenced from Employee PIN when an Employee is selected.
                        </div>
                    </group>
                    <notebook>
                        <page string="Fingerprints">
                            <field name="fingerprint_ids" readonly="1">
                                <list>
                                    <field name="finger_index"/>
                                    <field name="template_version"/>
                                    <field name="template_hash_short" string="Template Hash"/>
                                    <field name="template_length"/>
                                    <field name="status"/>
                                    <field name="source_device_code"/>
                                    <field name="last_collected_at"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_entry_control_user_search" model="ir.ui.view">
        <field name="name">entry.control.user.search</field>
        <field name="model">entry.control.user</field>
        <field name="arch" type="xml">
            <search string="Device Users">
                <field name="employee_id"/>
                <field name="pin"/>
                <field name="name"/>
                <field name="card_no"/>
                <filter name="active_users" string="Active" domain="[('is_active','=',True),('is_deleted','=',False)]"/>
                <filter name="disabled" string="Disabled" domain="[('is_active','=',False),('is_deleted','=',False)]"/>
                <filter name="deleted" string="Deleted" domain="[('is_deleted','=',True)]"/>
            </search>
        </field>
    </record>
    <record id="action_entry_control_user" model="ir.actions.act_window">
        <field name="name">Device Users</field>
        <field name="res_model">entry.control.user</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_entry_control_user_search"/>
    </record>
</odoo>
