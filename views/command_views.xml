<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_entry_control_command_list" model="ir.ui.view">
        <field name="name">entry.control.command.list</field>
        <field name="model">entry.control.command</field>
        <field name="arch" type="xml">
            <list string="Command Log" create="0" edit="0" delete="0">
                <field name="odoo_command_id" string="Command ID"/>
                <field name="create_date"/>
                <field name="command_type"/>
                <field name="pin"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>
    <record id="view_entry_control_command_form" model="ir.ui.view">
        <field name="name">entry.control.command.form</field>
        <field name="model">entry.control.command</field>
        <field name="arch" type="xml">
            <form string="Command Log" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="odoo_command_id" readonly="1"/>
                            <field name="create_date" readonly="1"/>
                        </group>
                        <group>
                            <field name="command_type" readonly="1"/>
                            <field name="pin" readonly="1"/>
                            <field name="user_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Payload">
                            <field name="payload" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_entry_control_command" model="ir.actions.act_window">
        <field name="name">Command Log</field>
        <field name="res_model">entry.control.command</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
